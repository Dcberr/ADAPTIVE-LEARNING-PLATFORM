---
config:
  flowchart:
    curve: linear
---
graph TD;
	__start__([<p>__start__</p>]):::first
	logic(logic)
	concept_map(concept_map)
	fix_hint(fix_hint)
	improve(improve)
	overview(overview)
	__end__([<p>__end__</p>]):::last
	__start__ --> logic;
	concept_map -.-> fix_hint;
	fix_hint -.-> improve;
	improve -.-> overview;
	logic -.-> concept_map;
	logic -.-> improve;
	overview --> __end__;
	classDef default fill:#f2f0ff,line-height:1.2
	classDef first fill-opacity:0
	classDef last fill:#bfb6fc
